{
  "name": "balistique-agent",
  "version": "1.0.0",
  "description": "Balistique Agent — personal AI assistant",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run src/index.ts",
    "dev:discord": "bun run src/index.ts --discord-only",
    "dev:chat": "bun run src/index.ts --chat",
    "dev:mail": "bun run src/index.ts --mail",
    "dev:mail-agent": "bun run src/index.ts --mail-agent",
    "dev:calendar-brief": "bun run src/index.ts --calendar-brief",
    "auth:login": "bun run src/index.ts --login",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "effect-language-service patch",
    "effect:docs": "effect-solutions list",
    "effect:show": "effect-solutions show"
  },
  "dependencies": {
    "@effect/ai-openai": "^4.0.0-beta.74",
    "@effect/platform-bun": "^4.0.0-beta.74",
    "discord.js": "^14.26.4",
    "effect": "^4.0.0-beta.74",
    "imapflow": "^1.3.4",
    "mailparser": "^3.9.9",
    "node-ical": "^0.26.1",
    "tsdav": "^2.2.2"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@types/bun": "^1.3.14",
    "@types/mailparser": "^3.4.6",
    "effect-solutions": "^0.5.3",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "^6.0.3"
  }
